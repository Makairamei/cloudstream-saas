# ============================================================
# CloudStream SaaS — Environment Variables Template
# Copy to .env and fill in your values
# ============================================================

# ── Database ──────────────────────────────────────────────
DB_USER=cloudstream
DB_PASSWORD=cs_secret_2026
DB_NAME=cloudstream_saas
DATABASE_URL=postgresql://cloudstream:cs_secret_2026@localhost:5432/cloudstream_saas?schema=public

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret_2026
REDIS_URL=redis://:redis_secret_2026@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT Auth ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_in_production_min64chars
JWT_REFRESH_SECRET=change_this_refresh_secret_also_very_long_min64chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Backend Server ────────────────────────────────────────
PORT=3001
NODE_ENV=development
BACKEND_URL=http://localhost:3001
# Public-facing URL used in plugins.json download links (MUST match what plugin clients connect to)
SERVER_URL=https://faxecez.eu.org

# ── Frontend ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_NAME=CloudStream Admin
NEXT_PUBLIC_APP_VERSION=2.0.0

# ── Storage ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
# S3 (optional)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ── SMTP (Email Notifications) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cloudstream.app

# ── Discord Webhook ───────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Telegram Bot ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Security ──────────────────────────────────────────────
MAX_FAILED_LOGINS=5
BLOCK_DURATION_MINUTES=30
SESSION_TIMEOUT_MINUTES=1440
BCRYPT_ROUNDS=12

# ── License Defaults ──────────────────────────────────────
DEFAULT_MAX_DEVICES=3
DEFAULT_GRACE_PERIOD_DAYS=3
LICENSE_KEY_PREFIX=CS

# ── Admin Seed (first run) ────────────────────────────────
SEED_ADMIN_EMAIL=admin@cloudstream.app
SEED_ADMIN_PASSWORD=Admin@123456
SEED_ADMIN_NAME=Super Admin
